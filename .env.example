# Copie para .env na raiz do suite antes de rodar docker compose

# Chave compartilhada entre back e bot (obrigatório trocar em produção)
SHARED_API_KEY=dev-shared-key-pizzaria

# JWT do back
JWT_SECRET=dev-jwt-secret-troque-em-producao

# Admin inicial (criado via: docker compose exec back npm run seed)
ADMIN_EMAIL=admin@pizzaria.local
ADMIN_PASSWORD=admin123
ADMIN_PHONE=5500000000000

# URL da API vista pelo NAVEGADOR (build do front)
NEXT_PUBLIC_API_BASE_URL=http://localhost:3001

# CORS do back (origem do front)
CORS_ORIGIN=http://localhost:3000

# Bot: números permitidos (vazio = padrão de dev; * = todos)
ALLOWED_NUMBERS=
# Bot: número (com DDI) avisado quando o cliente pede atendente humano
ATTENDANT_NUMBER=
